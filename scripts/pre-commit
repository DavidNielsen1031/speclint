#!/usr/bin/env bash
# Pre-commit hook: block commits containing secrets or sensitive patterns
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

RED='\033[0;31m'
NC='\033[0m'

# Patterns that should NEVER appear in committed code
# Each line: regex | human-readable label
PATTERNS=(
  'SK-INTERNAL-[A-F0-9]{16,}|Speclint internal API key'
  'sk-ant-[a-zA-Z0-9]{20,}|Anthropic API key'
  'sk-[a-zA-Z0-9]{20,}|OpenAI-style API key'
  'ANTHROPIC_API_KEY\s*=\s*['\''"][^'\''"]+|Hardcoded Anthropic key assignment'
  'ghp_[a-zA-Z0-9]{36}|GitHub personal access token'
  'gho_[a-zA-Z0-9]{36}|GitHub OAuth token'
  'xoxb-[a-zA-Z0-9-]+|Slack bot token'
  'xoxp-[a-zA-Z0-9-]+|Slack user token'
  'AKIA[0-9A-Z]{16}|AWS access key'
  'eyJ[a-zA-Z0-9_-]{50,}\.[a-zA-Z0-9_-]{50,}|JWT token (long)'
)

# Only scan staged files (what's actually being committed)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Skip binary files and lock files
FILTERED_FILES=$(echo "$STAGED_FILES" | grep -v -E '\.(png|jpg|jpeg|gif|webp|ico|pdf|woff|woff2|ttf|eot|svg)$' | grep -v 'package-lock\.json$' | grep -v 'bun\.lock$' || true)

if [ -z "$FILTERED_FILES" ]; then
  exit 0
fi

FOUND=0

for entry in "${PATTERNS[@]}"; do
  pattern="${entry%%|*}"
  label="${entry##*|}"

  # Check staged content (not working tree)
  matches=$(echo "$FILTERED_FILES" | xargs git diff --cached -G "$pattern" --name-only 2>/dev/null || true)

  if [ -n "$matches" ]; then
    if [ "$FOUND" -eq 0 ]; then
      echo ""
      echo -e "${RED}🚨 SECRET DETECTED — commit blocked${NC}"
      echo ""
    fi
    FOUND=1
    echo -e "  ${RED}▸${NC} $label"
    echo "$matches" | sed 's/^/    /'
    echo ""
  fi
done

if [ "$FOUND" -ne 0 ]; then
  echo "Fix: remove the secret, use environment variables instead."
  echo "Override: git commit --no-verify (use with extreme caution)"
  echo ""
  exit 1
fi

exit 0
